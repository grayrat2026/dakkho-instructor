# Database
DATABASE_URL="file:./dev.db"

# Appwrite
NEXT_PUBLIC_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
NEXT_PUBLIC_APPWRITE_PROJECT_ID=your-project-id
APPWRITE_DATABASE_ID=your-database-id
APPWRITE_API_KEY=your-appwrite-api-key

# Cloudflare R2
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_ACCOUNT_ID=your-account-id
R2_API_TOKEN=your-r2-api-token
R2_BUCKET_VIDEOS=dakkho-videos
R2_BUCKET_THUMBNAILS=dakkho-thumbnails
R2_BUCKET_AVATARS=dakkho-avatars
R2_BUCKET_RESOURCES=dakkho-resources

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=noreply@yourdomain.com
RESEND_SUPPORT_EMAIL=support@yourdomain.com

# HiveMQ MQTT
MQTT_BROKER_URL=wss://your-broker.hivemq.cloud:8884/mqtt
MQTT_USERNAME=your-mqtt-username
MQTT_PASSWORD=your-mqtt-password

# App
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# Supabase Edge Functions (for GitHub Pages deployment)
NEXT_PUBLIC_API_BASE_URL=https://your-project.supabase.co/functions/v1
